# Project Config
PROJECT_NAME=LockPay API
VERSION=0.1.0
API_V1_STR=/api/v1

# Security (generate a strong secret key using e.g. `openssl rand -hex 32`)
SECRET_KEY=your-strong-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Nomba API Config
NOMBA_BASE_URL=https://api.nomba.com
NOMBA_PARENT_ACCOUNT_ID=your-parent-account-id
NOMBA_SUB_ACCOUNT_ID=your-sub-account-id
NOMBA_TEST_CLIENT_ID=your-test-client-id
NOMBA_TEST_PRIVATE_KEY=your-test-private-key
NOMBA_LIVE_CLIENT_ID=your-live-client-id
NOMBA_LIVE_PRIVATE_KEY=your-live-private-key
NOMBA_WEBHOOK_SECRET=your-webhook-secret

# Database
DATABASE_URL=sqlite:///./lockpay.db
ENVIRONMENT=test

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-app.vercel.app

